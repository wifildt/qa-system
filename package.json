{
  "name": "@ldtdev/qa-system",
  "version": "1.1.2",
  "description": "Self-learning QA framework for frontend apps. Detect conventions, generate tests (via Claude Code CLI), validate, execute, self-heal, learn, evolve strategy.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "qa": "dist/bin/qa-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "qa": "tsx bin/qa-cli.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "playwright": "^1.57.0"
  },
  "peerDependencies": {
    "claude-code": "*"
  },
  "peerDependenciesMeta": {
    "claude-code": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "src/rules/",
    "src/prompts/",
    "src/agents/",
    "src/project-config.schema.json",
    "presets/"
  ],
  "keywords": [
    "qa",
    "testing",
    "playwright",
    "multi-agent",
    "self-healing",
    "ai-testing",
    "experience-library",
    "strategy-evolution",
    "claude-code"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wifildt/qa-system"
  },
  "homepage": "https://github.com/wifildt/qa-system",
  "bugs": {
    "url": "https://github.com/wifildt/qa-system/issues"
  },
  "license": "MIT"
}
