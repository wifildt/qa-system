        { "key": "7.1", "name": "Buoi hop phu huynh (Parent Meetings)", "editable_by": ["gvcn"] },
        { "key": "7.2", "name": "BHYT va khoan kinh phi (Insurance/Fees)", "editable_by": ["gvcn"] },
