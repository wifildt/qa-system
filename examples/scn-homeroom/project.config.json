  "selectors": {
    "priority": ["data-testid", "aria-label", "role", "text"],
    "testid_attribute": "data-testid",
    "forbidden_patterns": [".ant-*", ".sc-*", ".css-*", ":nth-child(", "[class*="]
  },

  "test_runner": {
    "unit": "vitest",
    "e2e": "playwright",
    "browser": "chromium",
    "base_url": "https://test.lms360.vn",
    "viewport": { "width": 1440, "height": 900 },
    "locale": "vi-VN"
  },

  "conventions": {
    "file_naming": "PascalCase",
    "component_pattern": "function",
    "api_pattern": "functional",
    "form_library": "react-hook-form",
    "i18n": false
  }
}
